{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug: Launch (stock)",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}",
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Debug: Launch (stock) with build flags",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}",
			"buildFlags": "-tags=dev",
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Debug: Attach to process",
			"type": "go",
			"request": "attach",
			"mode": "local",
			"processId": 0
		}
	]
}
